# Database Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Async URL for FastAPI app execution (SQLAlchemy asyncpg driver)
DATABASE_URL=postgresql+asyncpg://habitforge:habitforge_secret@127.0.0.1:5433/habitforge

# Sync URL for Alembic migrations (SQLAlchemy psycopg2 driver)
SYNC_DATABASE_URL=postgresql+psycopg2://habitforge:habitforge_secret@127.0.0.1:5433/habitforge

# Authentication Security Settings
# ─────────────────────────────────────────────────────────────────────────────

# ⚠️  CRITICAL: GENERATE A NEW SECRET KEY BEFORE DEPLOYING TO PRODUCTION!
# Run this command to generate a secure key:
#   openssl rand -hex 32
# Then replace the value below with the output.
JWT_SECRET_KEY=supersecretkey123changeme_REPLACE_THIS

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Settings
# ─────────────────────────────────────────────────────────────────────────────

# Environment: "development" or "production"
APP_ENV=development

# CORS Allowed Origins (comma-separated list, no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Date Override (DEV/TESTING ONLY)
# ⚠️  Set to false in production! This endpoint allows time-travel for testing.
ALLOW_DATE_OVERRIDE=false
