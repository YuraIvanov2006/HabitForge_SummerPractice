# Database Configuration
# Async URL for FastAPI app execution (SQLAlchemy asyncpg)
DATABASE_URL=postgresql+asyncpg://habitforge:habitforge_secret@127.0.0.1:5433/habitforge

# Sync URL for Alembic migrations execution (SQLAlchemy psycopg2)
SYNC_DATABASE_URL=postgresql+psycopg2://habitforge:habitforge_secret@127.0.0.1:5433/habitforge

# Authentication Security Settings
JWT_SECRET_KEY=supersecretkey123changeme
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Allowed Origins (comma separated list)
ALLOWED_ORIGINS=http://localhost:5173
